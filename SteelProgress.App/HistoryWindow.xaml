<Window x:Class="SteelProgress.App.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historial"
        Height="850"
        Width="1100"
        Background="{StaticResource BgMain}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Historial de entrenamientos"
                           FontSize="30"
                           FontWeight="Bold"/>
                <TextBlock Text="Consulta tus sesiones registradas y sus detalles"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- SESIONES -->
        <Border Grid.Row="1"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Sesiones registradas"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <DataGrid Grid.Row="1"
                          AutoGenerateColumns="False"
                          ItemsSource="{Binding Sessions}"
                          SelectedItem="{Binding SelectedSession, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding Date}" Width="220"/>
                        <DataGridTextColumn Header="Día" Binding="{Binding RoutineDay.Name}" Width="220"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- TÍTULO EJERCICIOS -->
        <TextBlock Grid.Row="2"
                   Text="Ejercicios de la sesión seleccionada"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- EJERCICIOS -->
        <Border Grid.Row="3"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,20">
            <DataGrid AutoGenerateColumns="False"
                      ItemsSource="{Binding SessionExercises}"
                      SelectedItem="{Binding SelectedExercise, Mode=TwoWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ejercicio"
                                        Binding="{Binding Exercise.Name}"
                                        Width="250"/>
                    <DataGridTextColumn Header="Series"
                                        Binding="{Binding Sets.Count}"
                                        Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- TÍTULO SETS -->
        <TextBlock Grid.Row="4"
                   Text="Series del ejercicio"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- SETS -->
        <Border Grid.Row="5"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20">
            <DataGrid AutoGenerateColumns="False"
                      ItemsSource="{Binding SelectedExerciseSets}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Peso"
                                        Binding="{Binding Weight}"
                                        Width="150"/>
                    <DataGridTextColumn Header="Reps"
                                        Binding="{Binding Reps}"
                                        Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>