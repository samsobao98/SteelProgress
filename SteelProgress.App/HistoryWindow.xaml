<Window x:Class="SteelProgress.App.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historial"
        Height="800"
        Width="1000">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Historial de entrenamientos"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <DataGrid Grid.Row="1"
                  Margin="0,0,0,20"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding Sessions}"
                  SelectedItem="{Binding SelectedSession, Mode=TwoWay}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding Date}" Width="220"/>
                <DataGridTextColumn Header="Día" Binding="{Binding RoutineDay.Name}" Width="220"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2"
                   Text="Detalle de la sesión seleccionada"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <DataGrid Grid.Row="3"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding SessionExercises}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ejercicio"
                                    Binding="{Binding Exercise.Name}"
                                    Width="250"/>
                <DataGridTextColumn Header="Series"
                                    Binding="{Binding Sets.Count}"
                                    Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>