<UserControl x:Class="SteelProgress.App.Views.WorkoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgMain}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Entrenamiento"
                           FontSize="30"
                           FontWeight="Bold"/>

                <TextBlock Text="Selecciona una rutina, inicia la sesión y registra tus series"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="15"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">

            <!-- PREPARACIÓN -->
            <Border Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="30"
                    Visibility="{Binding IsSessionActive, Converter={StaticResource InverseBoolToVisibilityConverter}}">

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Width="520">

                    <TextBlock Text="Preparar entrenamiento"
                               FontSize="32"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Elige qué día vas a entrenar para crear una sesión nueva."
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="15"
                               TextAlignment="Center"
                               Margin="0,0,0,30"/>

                    <TextBlock Text="Rutina" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Routines}"
                              SelectedItem="{Binding SelectedRoutine}"
                              DisplayMemberPath="Name"
                              Height="42"
                              Margin="0,0,0,18"/>

                    <TextBlock Text="Día de rutina" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding RoutineDays}"
                              SelectedItem="{Binding SelectedRoutineDay}"
                              DisplayMemberPath="Name"
                              Height="42"
                              Margin="0,0,0,30"/>

                    <Button Content="Iniciar entrenamiento"
                            Height="48"
                            FontSize="16"
                            FontWeight="Bold"
                            Command="{Binding StartWorkoutCommand}"/>
                </StackPanel>
            </Border>

            <!-- ENTRENAMIENTO ACTIVO -->
            <Grid Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource BgSecondary}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18"
                        Margin="0,0,20,0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Ejercicios"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Exercises}"
                                 SelectedItem="{Binding SelectedWorkoutExercise, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextMain}">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent"
                                            BorderBrush="{StaticResource BorderColor}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12"
                                            Margin="0,0,0,10">

                                        <StackPanel>
                                            <TextBlock Text="{Binding Exercise.Name}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"/>

                                            <TextBlock Text="Ejercicio de la sesión"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="12"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BgSecondary}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="28"
                            Margin="0,0,0,20">

                        <StackPanel>
                            <TextBlock Text="Ejercicio actual"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding SelectedWorkoutExercise.Exercise.Name, TargetNullValue=Selecciona un ejercicio}"
                                       FontSize="34"
                                       FontWeight="Bold"/>

                            <TextBlock Text="Introduce el peso y las repeticiones para registrar una nueva serie."
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="15"
                                       Margin="0,10,0,0"/>

                            <Button Content="Finalizar entrenamiento"
                                    Width="190"
                                    Height="38"
                                    Margin="0,20,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding FinishWorkoutCommand}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{StaticResource BgSecondary}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="22"
                            Margin="0,0,0,20">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                <TextBlock Text="Repeticiones"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,0,0,8"/>

                                <TextBox Text="{Binding Reps, Mode=TwoWay}"
                                         Height="48"
                                         FontSize="20"
                                         VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                <TextBlock Text="Peso (kg)"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,0,0,8"/>

                                <TextBox Text="{Binding Weight, Mode=TwoWay}"
                                         Height="48"
                                         FontSize="20"
                                         VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Content="+ Añadir serie"
                                    Width="170"
                                    Height="48"
                                    Margin="0,25,0,0"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Command="{Binding AddSetCommand}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Background="{StaticResource BgSecondary}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="22">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Series registradas"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,0,0,15"/>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding SelectedExerciseSets}"
                                     SelectedItem="{Binding SelectedWorkoutSet, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0">

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent"
                                                BorderBrush="{StaticResource BorderColor}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10"
                                                Margin="0,0,0,8">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Width="36"
                                                        Height="36"
                                                        CornerRadius="18"
                                                        Background="{StaticResource BgSecondary}"
                                                        BorderBrush="{StaticResource BorderColor}"
                                                        BorderThickness="1"
                                                        Margin="0,0,14,0">
                                                    <TextBlock Text="✓"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource Accent}"/>
                                                </Border>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Peso"
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock FontSize="20"
                                                               FontWeight="Bold">
                                                        <Run Text="{Binding Weight}"/>
                                                        <Run Text=" kg"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Reps"
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock FontSize="20"
                                                               FontWeight="Bold">
                                                        <Run Text="x"/>
                                                        <Run Text="{Binding Reps}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Button Grid.Row="2"
                                    Content="Eliminar serie seleccionada"
                                    Width="220"
                                    Height="38"
                                    HorizontalAlignment="Left"
                                    Margin="0,15,0,0"
                                    Command="{Binding DeleteSetCommand}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>