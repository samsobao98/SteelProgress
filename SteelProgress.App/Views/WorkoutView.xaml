<UserControl x:Class="SteelProgress.App.Views.WorkoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgMain}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="240"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Entrenamiento"
                               FontSize="30"
                               FontWeight="Bold"/>
                    <TextBlock Text="Selecciona un ejercicio y registra tus series"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Ejercicios de la sesión"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <DataGrid Grid.Row="1"
                              AutoGenerateColumns="False"
                              ItemsSource="{Binding Exercises}"
                              SelectedItem="{Binding SelectedWorkoutExercise, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ejercicio"
                                                Binding="{Binding Exercise.Name}"
                                                Width="*"
                                                ElementStyle="{StaticResource DataGridTextCellStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Repeticiones" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Reps, Mode=TwoWay}"
                                 Height="36"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="Peso" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Weight, Mode=TwoWay}"
                                 Height="36"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="Añadir serie"
                            Width="140"
                            Height="36"
                            Margin="0,24,10,0"
                            Command="{Binding AddSetCommand}"/>

                    <Button Grid.Column="3"
                            Content="Eliminar serie"
                            Width="140"
                            Height="36"
                            Margin="0,24,0,0"
                            Command="{Binding DeleteSetCommand}"/>
                </Grid>
            </Border>

            <TextBlock Grid.Row="3"
                       Text="Series del ejercicio seleccionado"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <Border Grid.Row="4"
                    Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20">
                <DataGrid AutoGenerateColumns="False"
                          ItemsSource="{Binding SelectedExerciseSets}"
                          SelectedItem="{Binding SelectedWorkoutSet, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Peso"
                                            Binding="{Binding Weight}"
                                            Width="150"
                                            ElementStyle="{StaticResource DataGridTextCellStyle}"/>
                        <DataGridTextColumn Header="Reps"
                                            Binding="{Binding Reps}"
                                            Width="150"
                                            ElementStyle="{StaticResource DataGridTextCellStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>