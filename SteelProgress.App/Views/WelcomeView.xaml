<UserControl x:Class="SteelProgress.App.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgMain}">

    <Grid>
        <!-- FONDO DECORATIVO -->
        <Ellipse Width="420"
                 Height="420"
                 Fill="{StaticResource Accent}"
                 Opacity="0.08"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-160,-120,0"/>

        <Ellipse Width="300"
                 Height="300"
                 Fill="{StaticResource Accent}"
                 Opacity="0.05"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Bottom"
                 Margin="-100,0,0,-100"/>

        <!-- CARD CENTRAL -->
        <Border x:Name="MainBorder"
                Width="620"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="42"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform Y="30"/>
            </Border.RenderTransform>

            <StackPanel>

                <TextBlock Text="STEEL"
                           FontSize="52"
                           FontWeight="Bold"
                           TextAlignment="Center"/>

                <TextBlock Text="PROGRESS"
                           FontSize="52"
                           FontWeight="Bold"
                           Foreground="{StaticResource Accent}"
                           TextAlignment="Center"
                           Margin="0,-10,0,0"/>

                <TextBlock Text="Registra. Analiza. Progresa."
                           FontSize="20"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Margin="0,22,0,0"/>

                <TextBlock Text="Controla tus rutinas, guarda tus entrenamientos y visualiza tu evolución con datos reales."
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="15"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,12,0,32"/>

                <UniformGrid Columns="3"
                             Margin="0,0,0,34">

                    <StackPanel Margin="8">
                        <TextBlock Text="🏋"
                                   FontSize="28"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Entrena"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="Registra series y peso"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextAlignment="Center"
                                   FontSize="12"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="8">
                        <TextBlock Text="📈"
                                   FontSize="28"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Progresa"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="Consulta gráficas"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextAlignment="Center"
                                   FontSize="12"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="8">
                        <TextBlock Text="🕘"
                                   FontSize="28"
                                   TextAlignment="Center"/>
                        <TextBlock Text="Compara"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="Revisa tu historial"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextAlignment="Center"
                                   FontSize="12"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                </UniformGrid>

                <Button Content="Empezar"
                        Height="52"
                        Width="220"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        FontWeight="Bold"
                        Click="Start_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>