<Window x:Class="SteelProgress.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SteelProgress"
        Height="750"
        Width="1250"
        Background="{StaticResource BgMain}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,1,0">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- BOTÓN TOGGLE -->
                <Button x:Name="ToggleSidebarButton"
                        Grid.Row="0"
                        Content="☰"
                        Width="45"
                        Height="45"
                        HorizontalAlignment="Left"
                        Click="ToggleSidebar_Click"/>

                <!-- LOGO / TÍTULO -->
                <StackPanel Grid.Row="1" Margin="0,20,0,20">
                    <TextBlock x:Name="SidebarTitle"
                               Text="SteelProgress"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="10,0,0,5"/>
                    <TextBlock x:Name="SidebarSubtitle"
                               Text="Training Tracker"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="10,0,0,0"/>
                </StackPanel>

                <!-- MENÚ -->
                <StackPanel Grid.Row="2">
                    <Button x:Name="BtnInicio"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenHomeView_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnInicioText" Text="Inicio"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnEjercicios"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenExerciseView_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💪" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnEjerciciosText" Text="Ejercicios"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnRutinas"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenRoutineWindow_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnRutinasText" Text="Rutinas"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnEntrenamiento"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenWorkoutWindow_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏋" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnEntrenamientoText" Text="Entrenamiento"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnHistorial"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenHistoryWindow_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🕘" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnHistorialText" Text="Historial"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Column="1">
            <ContentControl x:Name="MainContent"/>
        </Grid>
    </Grid>
</Window>