<Window x:Class="SteelProgress.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SteelProgress - Ejercicios" Height="500" Width="900">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Gestión de ejercicios"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="295,0,0,10">

            <Button Content="Rutinas"
                    Width="120"
                    Height="35"
                    Click="OpenRoutineWindow_Click"/>

            <Button Content="Entrenamiento"
                    Width="150"
                    Height="35"
                    Margin="10,0,0,0"
                    Click="OpenWorkoutWindow_Click"/>
            <Button Content="Historial"
                    Width="120"
                    Height="35"
                    Margin="10,0,0,0"
                    Click="OpenHistoryWindow_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,20">
            <TextBlock Text="Nombre"/>
            <TextBox Text="{Binding Name, Mode=TwoWay}" />

            <TextBlock Text="Grupo muscular"/>
            <TextBox Text="{Binding MuscleGroup, Mode=TwoWay}" />

            <TextBlock Text="Notas"/>
            <TextBox Text="{Binding Notes, Mode=TwoWay}" />

            <Button x:Name="BtnAddExercise"
                    Content="Añadir ejercicio"
                    Width="150"
                    Height="35"
                    Command="{Binding AddExerciseCommand}"/>

            <Button x:Name="BtnDeleteExercise"
                    Content="Eliminar ejercicio seleccionado"
                    Width="220"
                    Height="35"
                    Margin="0,10,0,0"
                    Command="{Binding DeleteExerciseCommand}"/>

            <Button x:Name="BtnUpdateExercise"
                    Content="Actualizar ejercicio seleccionado"
                    Width="220"
                    Height="35"
                    Margin="0,10,0,0"
                    Command="{Binding UpdateExerciseCommand}"/>
        </StackPanel>

        <DataGrid x:Name="DgExercises"
          Grid.Row="2"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          ItemsSource="{Binding Exercises}"
          SelectedItem="{Binding SelectedExercise, Mode=TwoWay}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Grupo muscular" Binding="{Binding MuscleGroup}" Width="200"/>
                <DataGridTextColumn Header="Notas" Binding="{Binding Notes}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
   