<Window x:Class="SteelProgress.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SteelProgress"
        Height="700"
        Width="1100"
        Background="{StaticResource BgMain}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border x:Name="SidebarPanel"
                Grid.Column="0"
                Width="220"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,1,0">

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- BOTÓN COLAPSAR -->
                <Button Grid.Row="0"
                        Content="☰"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,20"
                        Click="ToggleSidebar_Click"/>

                <!-- MENÚ -->
                <StackPanel Grid.Row="1" Margin="0,20,0,0">

                    <Button x:Name="BtnInicio"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenHomeView_Click">
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="🏠" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnInicioText" Text="Inicio"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnEjercicios"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenExerciseView_Click">
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="💪" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnEjerciciosText" Text="Ejercicios"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnRutinas"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenRoutineWindow_Click">
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="📋" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnRutinasText" Text="Rutinas"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnEntrenamiento"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenWorkoutWindow_Click">
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="🏋" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnEntrenamientoText" Text="Entrenamiento"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnHistorial"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenHistoryWindow_Click">
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="🕘" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnHistorialText" Text="Historial"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- LOGO + SALIR ABAJO -->
                <Grid Grid.Row="3"
      Margin="10,20,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                Orientation="Horizontal"
                VerticalAlignment="Center">

                        <Image x:Name="SidebarBottomLogo"
               Source="/logo_small.png"
               Width="36"
               Height="36"
               Margin="0,0,8,0"/>

                        <TextBlock x:Name="SidebarBottomText"
                   Text="SteelProgress"
                   FontSize="12"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="BtnSalir"
            Grid.Column="1"
            Content="↪"
            Width="36"
            Height="36"
            Click="Exit_Click"/>
                </Grid>
            </Grid>
        </Border>
                <!-- CONTENIDO -->
        <ContentControl x:Name="MainContent"
                Grid.Column="1"
                Opacity="1"/>


        <Border x:Name="ToastBorder"
        Grid.Column="1"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Width="320"
        Background="{StaticResource BgSecondary}"
        BorderBrush="{StaticResource BorderColor}"
        BorderThickness="1"
        CornerRadius="10"
        Padding="16"
        Margin="0,20,20,0"
        Visibility="Collapsed"
        Opacity="0">

            <StackPanel>
                <TextBlock x:Name="ToastTitle"
                   Text="Aviso"
                   FontSize="16"
                   FontWeight="Bold"/>

                <TextBlock x:Name="ToastMessage"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,6,0,0"/>
            </StackPanel>
        </Border>
        <Grid x:Name="ConfirmOverlay"
      Grid.Column="1"
      Background="#99000000"
      Visibility="Collapsed">

            <Border Width="420"
            Background="{StaticResource BgSecondary}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                <StackPanel>
                    <TextBlock x:Name="ConfirmTitle"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

                    <TextBlock x:Name="ConfirmMessage"
                       Foreground="{StaticResource TextSecondary}"
                       TextWrapping="Wrap"
                       FontSize="15"
                       Margin="0,0,0,24"/>

                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                        <Button Content="Cancelar"
                        Width="110"
                        Height="36"
                        Margin="0,0,10,0"
                        Click="CancelConfirm_Click"/>

                        <Button Content="Confirmar"
                        Width="110"
                        Height="36"
                        Click="AcceptConfirm_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
    
</Window>