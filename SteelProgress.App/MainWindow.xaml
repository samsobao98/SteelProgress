<Window x:Class="SteelProgress.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SteelProgress"
        Height="700"
        Width="1100"
        Background="{StaticResource BgMain}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,20">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="SteelProgress"
                               FontSize="30"
                               FontWeight="Bold"/>
                    <TextBlock Text="Gestión de ejercicios y entrenamiento"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Rutinas"
                            Width="120"
                            Height="38"
                            Margin="0,0,10,0"
                            Click="OpenRoutineWindow_Click"/>

                    <Button Content="Entrenamiento"
                            Width="140"
                            Height="38"
                            Margin="0,0,10,0"
                            Click="OpenWorkoutWindow_Click"/>

                    <Button Content="Historial"
                            Width="120"
                            Height="38"
                            Margin="0,0,10,0"
                            Click="OpenHistoryWindow_Click"/>

                    <Button Content="Progreso"
                            Width="120"
                            Height="38"
                            Click="OpenProgressWindow_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- FORMULARIO -->
        <Border Grid.Row="1"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="Nombre del ejercicio" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtName"
                             Text="{Binding Name, Mode=TwoWay}"
                             Height="36"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="Grupo muscular" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtMuscleGroup"
                             Text="{Binding MuscleGroup, Mode=TwoWay}"
                             Height="36"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,15,0">
                    <TextBlock Text="Notas" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtNotes"
                             Text="{Binding Notes, Mode=TwoWay}"
                             Height="36"/>
                </StackPanel>

                <Button Grid.Column="3"
                        Content="Añadir"
                        Width="110"
                        Height="36"
                        Margin="0,24,10,0"
                        Command="{Binding AddExerciseCommand}"/>

                <Button Grid.Column="4"
                        Content="Actualizar"
                        Width="110"
                        Height="36"
                        Margin="0,24,0,0"
                        Command="{Binding UpdateExerciseCommand}"/>
            </Grid>
        </Border>

        <!-- TABLA -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Ejercicios registrados"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <DataGrid x:Name="DgExercises"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Exercises}"
                          SelectedItem="{Binding SelectedExercise, Mode=TwoWay}"
                          Margin="0,0,0,15">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="220"/>
                        <DataGridTextColumn Header="Grupo muscular" Binding="{Binding MuscleGroup}" Width="220"/>
                        <DataGridTextColumn Header="Notas" Binding="{Binding Notes}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button Content="Eliminar ejercicio seleccionado"
                            Width="220"
                            Height="36"
                            Command="{Binding DeleteExerciseCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>