<Window x:Class="SteelProgress.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SteelProgress"
        Height="700"
        Width="1100"
        Background="{StaticResource BgMain}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,1,0">

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- BOTÓN COLAPSAR -->
                <Button Grid.Row="0"
                        Content="☰"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,20"
                        Click="ToggleSidebar_Click"/>

                <!-- MENÚ -->
                <StackPanel Grid.Row="1" Margin="0,20,0,0">

                    <Button x:Name="BtnInicio"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenHomeView_Click">
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="🏠" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnInicioText" Text="Inicio"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnEjercicios"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenExerciseView_Click">
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="💪" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnEjerciciosText" Text="Ejercicios"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnRutinas"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenRoutineWindow_Click">
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="📋" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnRutinasText" Text="Rutinas"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnEntrenamiento"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenWorkoutWindow_Click">
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="🏋" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnEntrenamientoText" Text="Entrenamiento"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnHistorial"
                            Height="45"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"
                            Click="OpenHistoryWindow_Click">
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="🕘" Margin="0,0,10,0"/>
                            <TextBlock x:Name="BtnHistorialText" Text="Historial"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <ContentControl x:Name="MainContent"
                Grid.Column="1"
                Opacity="1"/>
    </Grid>
</Window>