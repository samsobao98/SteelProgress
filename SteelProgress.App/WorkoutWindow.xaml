<Window x:Class="SteelProgress.App.WorkoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Entrenamiento"
        Height="600"
        Width="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Entrenamiento"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding Exercises}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ejercicio"
                                    Binding="{Binding Exercise.Name}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>