<Window x:Class="SteelProgress.App.WorkoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Entrenamiento"
        Height="800"
        Width="900">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Entrenamiento"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <DataGrid Grid.Row="1"
                      Margin="0,0,0,20"
                      AutoGenerateColumns="False"
                      ItemsSource="{Binding Exercises}"
                      SelectedItem="{Binding SelectedWorkoutExercise, Mode=TwoWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ejercicio"
                                        Binding="{Binding Exercise.Name}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2" Margin="0,0,0,20">
                <TextBlock Text="Añadir serie"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Repeticiones"/>
                <TextBox Text="{Binding Reps, Mode=TwoWay}" Margin="0,5,0,10"/>

                <TextBlock Text="Peso"/>
                <TextBox Text="{Binding Weight, Mode=TwoWay}" Margin="0,5,0,10"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Añadir serie"
                            Width="140"
                            Margin="0,0,10,0"
                            Command="{Binding AddSetCommand}"/>

                    <Button Content="Eliminar serie"
                            Width="140"
                            Command="{Binding DeleteSetCommand}"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Grid.Row="3"
                       Text="Series del ejercicio seleccionado"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <DataGrid Grid.Row="4"
                      AutoGenerateColumns="False"
                      ItemsSource="{Binding SelectedExerciseSets}"
                      SelectedItem="{Binding SelectedWorkoutSet, Mode=TwoWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Peso"
                                        Binding="{Binding Weight}"
                                        Width="150"/>
                    <DataGridTextColumn Header="Reps"
                                        Binding="{Binding Reps}"
                                        Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </ScrollViewer>
</Window>