<Window x:Class="SteelProgress.App.RoutineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rutinas"
        Height="950"
        Width="1100"
        Background="{StaticResource BgMain}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <!-- CABECERA -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Rutinas"
                               FontSize="30"
                               FontWeight="Bold"/>
                    <TextBlock Text="Organiza tus rutinas, días y ejercicios"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- FORMULARIO RUTINA -->
            <Border Grid.Row="1"
                    Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Nombre de la rutina" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Name, Mode=TwoWay}" Height="36"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="Notas" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Notes, Mode=TwoWay}" Height="36"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="Añadir rutina"
                            Width="140"
                            Height="36"
                            Margin="0,24,10,0"
                            Command="{Binding AddRoutineCommand}"/>

                    <Button Grid.Column="3"
                            Content="Eliminar rutina"
                            Width="140"
                            Height="36"
                            Margin="0,24,0,0"
                            Command="{Binding DeleteRoutineCommand}"/>
                </Grid>
            </Border>

            <!-- TABLA RUTINAS -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Rutinas registradas"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <DataGrid Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              ItemsSource="{Binding Routines}"
                              SelectedItem="{Binding SelectedRoutine, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80"/>
                            <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="220"/>
                            <DataGridTextColumn Header="Notas" Binding="{Binding Notes}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- TÍTULO DÍAS -->
            <TextBlock Grid.Row="3"
                       Text="Días de la rutina seleccionada"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <!-- FORMULARIO DÍA -->
            <Border Grid.Row="4"
                    Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Nombre del día" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding DayName, Mode=TwoWay}" Height="36"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Añadir día"
                            Width="140"
                            Height="36"
                            Margin="0,24,10,0"
                            Command="{Binding AddDayCommand}"/>

                    <Button Grid.Column="2"
                            Content="Eliminar día"
                            Width="140"
                            Height="36"
                            Margin="0,24,0,0"
                            Command="{Binding DeleteDayCommand}"/>
                </Grid>
            </Border>

            <!-- TABLA DÍAS -->
            <Border Grid.Row="5"
                    Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,20">
                <DataGrid AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          ItemsSource="{Binding RoutineDays}"
                          SelectedItem="{Binding SelectedRoutineDay, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Orden" Binding="{Binding Order}" Width="100"/>
                        <DataGridTextColumn Header="Nombre del día" Binding="{Binding Name}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- TÍTULO EJERCICIOS -->
            <TextBlock Grid.Row="6"
                       Text="Ejercicios del día seleccionado"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <!-- FORMULARIO EJERCICIOS -->
            <Border Grid.Row="7"
                    Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Selecciona un ejercicio" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding AllExercises}"
                                  SelectedItem="{Binding SelectedExerciseToAdd}"
                                  DisplayMemberPath="Name"
                                  Height="36"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Añadir ejercicio"
                            Width="150"
                            Height="36"
                            Margin="0,24,10,0"
                            Command="{Binding AddExerciseToDayCommand}"/>

                    <Button Grid.Column="2"
                            Content="Eliminar ejercicio"
                            Width="150"
                            Height="36"
                            Margin="0,24,0,0"
                            Command="{Binding DeleteExerciseFromDayCommand}"/>
                </Grid>
            </Border>

            <!-- TABLA EJERCICIOS -->
            <Border Grid.Row="8"
                    Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20">
                <DataGrid AutoGenerateColumns="False"
                          ItemsSource="{Binding DayExercises}"
                          SelectedItem="{Binding SelectedDayExercise, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Orden" Binding="{Binding Order}" Width="100"/>
                        <DataGridTextColumn Header="Ejercicio" Binding="{Binding Exercise.Name}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>